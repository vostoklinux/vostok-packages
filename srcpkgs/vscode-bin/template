# Template file for 'vscode'
pkgname=vscode-bin
version=1.113.0
revision=8
archs="x86_64"
wrksrc="VSCode-linux-x64"
distfiles=("https://update.code.visualstudio.com/${version}/linux-x64/stable>code-${version}.tar.gz")
checksum=2681040089faf143bed37246f2b0bc0787f6d342d878b1ec4b3737b38833c088
homepage="https://code.visualstudio.com"
license="custom:Microsoft EULA"
short_desc="Visual Studio Code - proprietary source code editor"
maintainer="Vostok Linux <vostoklinux.org>"
nostrip=yes

depends="alsa-lib at-spi2-core cairo cups dbus expat fontconfig freetype
 gdk-pixbuf glib gtk+3 libX11 libXScrnSaver libXcomposite libXdamage libXext
 libXfixes libXrandr libXrender libXtst libdrm nss nspr libxcb libxshmfence
 mesa pango eudev-libudev libgbm libsecret"

do_install() {
	vmkdir usr/lib/vscode

	vcopy "${wrksrc}/*" usr/lib/vscode

	vmkdir usr/bin
	ln -sf /usr/lib/vscode/bin/code ${DESTDIR}/usr/bin/code

	if [ -f "${wrksrc}/resources/app/resources/linux/code.desktop" ]; then
		vinstall "${wrksrc}/resources/app/resources/linux/code.desktop" 644 usr/share/applications
	else
		cat > code.desktop <<EOF
[Desktop Entry]
Name=Visual Studio Code
Comment=Code Editing. Redefined.
Exec=/usr/bin/code
Icon=vscode
Terminal=false
Type=Application
Categories=Development;IDE;
StartupWMClass=Code
EOF
		vinstall code.desktop 644 usr/share/applications
	fi

	if [ -f "${wrksrc}/resources/app/resources/linux/code.png" ]; then
		vinstall "${wrksrc}/resources/app/resources/linux/code.png" 644 usr/share/pixmaps
		vmkdir usr/share/icons/hicolor/48x48/apps
		cp "${wrksrc}/resources/app/resources/linux/code.png" ${DESTDIR}/usr/share/icons/hicolor/48x48/apps/vscode.png
	fi

	if [ -f "${wrksrc}/LICENSE" ]; then
		vlicense "${wrksrc}/LICENSE"
	elif [ -f "${wrksrc}/LICENSES.chromium.html" ]; then
		vlicense "${wrksrc}/LICENSES.chromium.html"
	else
		vmkdir usr/share/licenses/${pkgname}
		echo "Visual Studio Code is licensed under the Microsoft EULA." > ${DESTDIR}/usr/share/licenses/${pkgname}/LICENSE
	fi
}