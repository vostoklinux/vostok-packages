# Template file for 'asar'
pkgname=asar
version=4.2.0
revision=1
hostmakedepends="nodejs"
depends="nodejs"
short_desc="Creating Electron app packages"
maintainer="nerdyslacker <karyan40024@gmail.com>"
license="MIT"
homepage="https://github.com/electron/asar"
distfiles="https://github.com/electron/asar/archive/refs/tags/v${version}.tar.gz"
checksum="f2eeb5710e3401d3a82ffe7c2c919f404a788bfba85693e3673663e2103f2d2a"


do_build() {
    export ELECTRON_SKIP_BINARY_DOWNLOAD=1
    npm install --force
    npm run build
}

do_install() {
    npm install --install-links -g --prefix ${DESTDIR}/usr .
    vlicense ${DESTDIR}/usr/lib/node_modules/@electron/asar/LICENSE.md
}
