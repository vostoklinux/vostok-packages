# Template file for 'portainer'
pkgname=portainer
version=2.39.3
revision=1
archs="x86_64"
wrksrc="portainer-${version}"
hostmakedepends="libarchive"
short_desc="Lightweight container management UI"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="Zlib"
homepage="https://www.portainer.io/"
distfiles="https://github.com/portainer/portainer/releases/download/${version}/portainer-${version}-linux-amd64.tar.gz"
checksum=6f5eaeb5968e355fcf40409d89085d569ac48ae099cca80ac6338c8aadae287e
nostrip=yes
noshlibs=yes
noverifyrdeps=yes
skip_extraction=yes

depends="glibc"

do_extract() {
    mkdir -p "${wrksrc}"
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/portainer-${version}-linux-amd64.tar.gz \
        --strip-components 1 -C "${wrksrc}"
}

do_install() {
    vmkdir opt/portainer
    vcopy "*" opt/portainer

    vmkdir usr/bin
    ln -sf /opt/portainer/portainer ${DESTDIR}/usr/bin/portainer

    if [ -f LICENSE ]; then
        vlicense LICENSE
    elif [ -f LICENSE.md ]; then
        vlicense LICENSE.md
    else
        vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
    fi
}