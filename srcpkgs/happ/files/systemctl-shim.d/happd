# systemctl-shim registry entry, installed by the happ package.
# Maps the systemd unit "happd.service" onto the runit service /etc/sv/happd,
# so the Happ GUI's `systemctl enable/start happd.service` calls work on Void.
# The defaults below match this package; override only if the layout changes.
service=happd
source=/etc/sv/happd
procname=happd
