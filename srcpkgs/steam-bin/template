do_install() {
    make DESTDIR=${DESTDIR} install
    rm -rf ${DESTDIR}/etc/apt ${DESTDIR}/usr/share/keyrings
    ln -sf /bin/true ${DESTDIR}/usr/bin/steamdeps
    vlicense steam_subscriber_agreement.txt LICENSE
}