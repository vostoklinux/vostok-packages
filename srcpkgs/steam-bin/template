 liberation-fonts-ttf file tar bash coreutils lsof steam-udev-rules
 libgcc-32bit libstdc++-32bit
 libX11-32bit libXext-32bit libXrandr-32bit libXrender-32bit libXfixes-32bit
 libXcomposite-32bit libXdamage-32bit libXinerama-32bit libXi-32bit libXcursor-32bit
 libxcb-32bit libxshmfence-32bit
