# Template file for 'brave'
pkgname=brave
version=1.90.121
revision=1
archs="x86_64"
wrksrc="."
depends="alsa-lib libsecret libgbm eudev-libudev libpulseaudio libcups"
short_desc="Web browser that blocks ads and trackers by default"
maintainer="David Ivashevich <davidivashevich@gmail.com>"
license="MPL-2.0"
homepage="https://brave.com"
distfiles="https://github.com/brave/brave-browser/releases/download/v${version}/brave-browser-${version}-linux-amd64.zip>brave-${version}-linux-amd64.zip"
checksum=565cd303d3dea5f2e42b1eb74627571fff9e832430329f489d86d7f0892b02e9
nostrip=yes

do_install() {
	vmkdir opt/brave
	vcopy "*" opt/brave
	vmkdir usr/bin
	ln -sf /opt/brave/brave ${DESTDIR}/usr/bin/brave

	vinstall ${FILESDIR}/brave.desktop 644 usr/share/applications

	for size in 16 24 32 48 64 128 256; do
		[ -f product_logo_${size}.png ] || continue
		vinstall product_logo_${size}.png 644 \
			usr/share/icons/hicolor/${size}x${size}/apps brave.png
	done
	vinstall product_logo_128.png 644 usr/share/pixmaps brave.png

	vlicense LICENSE
}

