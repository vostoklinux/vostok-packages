# Template file for 'codewhale'
pkgname=codewhale
version=0.9.0
revision=1
archs="x86_64"
wrksrc="codewhale-${version}"
hostmakedepends="libarchive"
short_desc="Your AI coding companion"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://github.com/Hmbown/CodeWhale"
distfiles="https://github.com/Hmbown/CodeWhale/releases/download/v${version}/codewhale-linux-x64 https://github.com/Hmbown/CodeWhale/releases/download/v${version}/codewhale-tui-linux-x64"
checksum="
 a01749d4d0f4cebbf1fb62e5c9f393cb5c05b570da144176238e740552de8fca
 08a142fc255f23e00e049416d4ea53f7fb77e026e093ebdfad16847c0906c85b
"
nostrip=yes
noshlibs=yes
noverifyrdeps=yes
skip_extraction=yes

depends="glibc"

do_extract() {
    mkdir -p "${wrksrc}"
    cp ${XBPS_SRCDISTDIR}/${pkgname}-${version}/codewhale-linux-x64 "${wrksrc}/codewhale"
    cp ${XBPS_SRCDISTDIR}/${pkgname}-${version}/codewhale-tui-linux-x64 "${wrksrc}/codewhale-tui"
    chmod +x "${wrksrc}/codewhale" "${wrksrc}/codewhale-tui"
}

do_install() {
    vbin codewhale
    vbin codewhale-tui
    vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
}