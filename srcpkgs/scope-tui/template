# Template file for 'scope-tui'
pkgname=scope-tui
version=0.3.5
revision=1
archs="x86_64"
wrksrc="scope-tui-${version}"
hostmakedepends="libarchive"
short_desc="Oscilloscope/spectroscope/specgram for your terminal"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://github.com/alemidev/scope-tui"
distfiles="https://github.com/alemidev/scope-tui/releases/download/v${version}/scope-tui-v${version}-linux-x64-gnu"
checksum=29676ac14a16ba51a28a104a5b45e200617e78e7213720adc404a25654b000d0
nostrip=yes
noshlibs=yes
noverifyrdeps=yes
skip_extraction=yes

depends="glibc"

do_extract() {
    mkdir -p "${wrksrc}"
    cp ${XBPS_SRCDISTDIR}/${pkgname}-${version}/scope-tui-v${version}-linux-x64-gnu "${wrksrc}/scope-tui"
    chmod +x "${wrksrc}/scope-tui"
}

do_install() {
    vbin scope-tui
    vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
}