pre_configure() {
	CFLAGS="${CFLAGS/ -g/ -g1}"
	
	CXXFLAGS="${CXXFLAGS/ -g/ -g1}"
}

post_install() {
	if [ -f ${DESTDIR}/usr/bin/ayugram-desktop ]; then
		mv ${DESTDIR}/usr/bin/ayugram-desktop ${DESTDIR}/usr/bin/ayugram
	elif [ -f ${DESTDIR}/usr/bin/telegram-desktop ]; then
		mv ${DESTDIR}/usr/bin/telegram-desktop ${DESTDIR}/usr/bin/ayugram
	fi
}
