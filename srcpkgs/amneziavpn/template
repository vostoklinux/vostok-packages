# Template file for 'amneziavpn'
pkgname=amneziavpn
version=4.8.19.0
revision=1
archs="x86_64"
wrksrc="${pkgname}-${version}"
hostmakedepends="p7zip python3"
short_desc="Amnezia VPN Client"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="GPL-3.0-only"
homepage="https://github.com/amnezia-vpn/amnezia-client"
distfiles="https://github.com/amnezia-vpn/amnezia-client/releases/download/${version}/AmneziaVPN_${version}_linux_x64.tar"
checksum=0b3da257ec93b7f1acc9f90913a6354bf583590e01a33791cd7cf7bb3be1c3b8
nopie=yes
noverifyrdeps=yes
disable_shlib_provides=yes

do_extract() {
	mkdir -p ${wrksrc}
	bsdtar -xf "${XBPS_SRCDISTDIR}/${pkgname}-${version}/AmneziaVPN_${version}_linux_x64.tar" \
		-C ${wrksrc}
}

post_extract() {
	local installer
	installer=$(find ${wrksrc} -name "*.bin" | head -1)
	[ -z "${installer}" ] && msg_error "amneziavpn: installer .bin not found"
	echo "=> Installer: ${installer} ($(du -sh ${installer} | cut -f1))"

	python3 - "${installer}" "${wrksrc}" << 'PYEOF'
import sys, os, subprocess

installer, wrksrc = sys.argv[1], sys.argv[2]
sig = b'\x37\x7a\xbc\xaf\x27\x1c'

with open(installer, 'rb') as f:
    data = f.read()

offsets = []
idx = 0
while True:
    pos = data.find(sig, idx)
    if pos < 0:
        break
    offsets.append(pos)
    idx = pos + 1

print(f"Found {len(offsets)} 7z signatures: {offsets}")

best_offset = None
best_count = 0
out_7z = os.path.join(wrksrc, "data.7z")

for offset in reversed(offsets):
    size = len(data) - offset
    print(f"Trying offset {offset} ({size/1024/1024:.1f} MB)...")

    with open(out_7z, 'wb') as f:
        f.write(data[offset:])

    r = subprocess.run(
        ["7z", "l", out_7z],
        capture_output=True, text=True
    )

    count = r.stdout.count('\n')
    print(f"  Listed lines: {count}, returncode: {r.returncode}")

    if count > best_count:
        best_count = count
        best_offset = offset

    if 'client' in r.stdout and 'service' in r.stdout:
        print(f"  => MATCH: contains client and service dirs")
        break

if best_offset is None:
    print("ERROR: No valid archive found")
    sys.exit(1)

print(f"=> Using offset {best_offset}")
with open(out_7z, 'wb') as f:
    f.write(data[best_offset:])

out_dir = os.path.join(wrksrc, "AmneziaVPN")
os.makedirs(out_dir, exist_ok=True)
r = subprocess.run(
    ["7z", "x", out_7z, f"-o{out_dir}", "-y"],
    capture_output=True, text=True
)
print(r.stdout[-500:] if len(r.stdout) > 500 else r.stdout)
if r.returncode not in (0, 1):
    print(f"STDERR: {r.stderr[-200:]}")
os.remove(out_7z)
os.remove(installer)
print("=> Done")
PYEOF

	rm -f ${wrksrc}/AmneziaVPN/client/bin/*.sha256 2>/dev/null || true

	echo "=> AmneziaVPN contents:"
	ls -la ${wrksrc}/AmneziaVPN/ || true

	[ -d "${wrksrc}/AmneziaVPN/client/bin" ] \
		|| msg_error "amneziavpn: client/bin not found — extraction failed"

	echo "=> OK: $(ls ${wrksrc}/AmneziaVPN/client/bin/ | wc -l) binaries"
}

do_install() {
	sed -i 's#/usr/share/pixmaps/AmneziaVPN.png#AmneziaVPN#g' \
		${wrksrc}/AmneziaVPN/AmneziaVPN.desktop

	vmkdir opt/AmneziaVPN
	vcopy "${wrksrc}/AmneziaVPN/client" opt/AmneziaVPN
	vcopy "${wrksrc}/AmneziaVPN/service" opt/AmneziaVPN

	chmod +x ${DESTDIR}/opt/AmneziaVPN/client/bin/*
	chmod +x ${DESTDIR}/opt/AmneziaVPN/client/AmneziaVPN.sh
	chmod +x ${DESTDIR}/opt/AmneziaVPN/service/bin/AmneziaVPN-service
	chmod +x ${DESTDIR}/opt/AmneziaVPN/service/AmneziaVPN-service.sh

	vmkdir usr/bin
	ln -sf /opt/AmneziaVPN/client/AmneziaVPN.sh ${DESTDIR}/usr/bin/AmneziaVPN

	vinstall ${wrksrc}/AmneziaVPN/AmneziaVPN.desktop 644 usr/share/applications
	vinstall ${wrksrc}/AmneziaVPN/AmneziaVPN.png 644 \
		usr/share/icons/hicolor/512x512/apps
	vinstall ${wrksrc}/AmneziaVPN/AmneziaVPN.png 644 usr/share/pixmaps

	vsv amneziavpn
}