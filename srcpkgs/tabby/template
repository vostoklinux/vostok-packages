# Template file for 'tabby'
pkgname=tabby
version=1.0.235
revision=1
archs="x86_64"
wrksrc="tabby-${version}"
short_desc="Terminal for the modern age with SSH client and serial terminal"
maintainer="cybarchitect <cybarchitect@gmail.com>"
license="MIT"
homepage="https://tabby.sh/"
distfiles="https://github.com/Eugeny/tabby/releases/download/v${version}/tabby-${version}-linux-x64.deb"
checksum=eccdc34d6d17ef864d59bba1cd04d7ed4a0c27b102bdcd1ede9bdab2d693e91a
nostrip=yes
noshlibs=yes
noverifyrdeps=yes
depends="libsecret libgbm eudev-libudev alsa-lib libcups libpulseaudio"

do_extract() {
    mkdir -p ${wrksrc}
    bsdtar -xf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/tabby-${version}-linux-x64.deb \
        -C ${wrksrc} --include='data.tar*'
    bsdtar -xf ${wrksrc}/data.tar* -C ${wrksrc}
    rm ${wrksrc}/data.tar*
}

do_install() {
    vmkdir opt/tabby
    vcopy "*" opt/tabby
    vcopy ".[!.]*" opt/tabby 2>/dev/null || true

    vmkdir usr/bin
    ln -sf /opt/tabby/opt/Tabby/tabby ${DESTDIR}/usr/bin/tabby

    for size in 16x16 32x32 64x64 128x128 256x256 512x512; do
        if [ -f usr/share/icons/hicolor/${size}/apps/tabby.png ]; then
            vmkdir usr/share/icons/hicolor/${size}/apps
            vcopy usr/share/icons/hicolor/${size}/apps/tabby.png usr/share/icons/hicolor/${size}/apps
        fi
    done
    vmkdir usr/share/pixmaps
    vcopy usr/share/icons/hicolor/256x256/apps/tabby.png usr/share/pixmaps 2>/dev/null || true

    vmkdir usr/share/applications
    vinstall ${FILESDIR}/tabby.desktop 644 usr/share/applications

    vinstall ${FILESDIR}/LICENSE 644 usr/share/licenses/${pkgname}
}