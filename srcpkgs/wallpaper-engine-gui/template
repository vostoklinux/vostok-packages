do_install() {
	vlicense LICENSE

	vmkdir opt/linux-wallpaper-engine/
	mv * ${DESTDIR}/opt/linux-wallpaper-engine/

	vbin ${FILESDIR}/linux-wallpaper-engine.sh linux-wallpaper-engine

	vmkdir usr/share/applications
	vinstall ${FILESDIR}/linux-wallpaper-engine.desktop 644 usr/share/applications/
}
