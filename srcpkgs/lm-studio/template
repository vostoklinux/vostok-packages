# Template file for 'lm-studio'
pkgname=lm-studio
version=0.4.2
revision=2
archs="x86_64"
wrksrc="lmstudio-${version}"
hostmakedepends="fuse"
distfiles="https://installers.lmstudio.ai/linux/x64/${version}-${revision}/LM-Studio-${version}-${revision}-x64.AppImage"
checksum="2711a5aa0b2e2dc5bcd66388727b551521efd7dcd2168b880a1833fde81cf89d"
homepage="https://lmstudio.ai/"
license="custom:EULA"
short_desc="LM Studio - A desktop app for exploring and running large language models locally (AppImage repack)"
maintainer="Vostok Linux <vostoklinux.org>"
nostrip=yes
python_version=3
noshlibs=yes
python_shebang_whitelist="/opt/lm-studio/*"
shlib_provides="libffmpeg.so libcublas.so.11 libcublasLt.so.11 libcudart.so.11.0 
 libvulkan.so.1 libpython3.11.so.1.0 libcuda.so.1 libdbusmenu-gtk.so.4 
 libggml-base.so libggml-cpu.so libggml-cuda.so libggml-vulkan.so 
 libggml_llamacpp.so libllama.so libllm_engine.so liblmstudiocore.so 
 libmtmd.so libvips-cpp.so.42 libindicator.so.7
 \$ORIGIN/../lib/libpython3.11.so.1.0"

depends="hicolor-icon-theme xdg-utils nss nspr glib dbus-libs 
 alsa-lib at-spi2-core cairo cups expat fontconfig freetype 
 gdk-pixbuf gtk+3 libX11 libXcomposite libXdamage libXext 
 libXfixes libXrandr libXrender libXtst libdrm libgbm libsecret 
 libxcb xcb-util-cursor libXinerama libxshmfence mesa-dri 
 libdbusmenu-gtk3 pango"

do_extract() {
	cd ${XBPS_BUILDDIR}

	chmod +x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/LM-Studio-${version}-${revision}-x64.AppImage
	
	${XBPS_SRCDISTDIR}/${pkgname}-${version}/LM-Studio-${version}-${revision}-x64.AppImage --appimage-extract
	
	rm -rf ${pkgname}-${version}
	
	mv squashfs-root ${pkgname}-${version}
}

do_install() {
	vmkdir opt/lm-studio
	vcopy "*" opt/lm-studio

	find ${DESTDIR}/opt/lm-studio -type d -exec chmod 755 {} +
	find ${DESTDIR}/opt/lm-studio -type f -exec chmod 644 {} +

	chmod -R 755 ${DESTDIR}/opt/lm-studio

	if [ -f ${DESTDIR}/opt/lm-studio/chrome-sandbox ]; then
		chmod 4755 ${DESTDIR}/opt/lm-studio/chrome-sandbox
	fi

	if [ -f ${DESTDIR}/opt/lm-studio/chrome_crashpad_handler ]; then
		chmod 755 ${DESTDIR}/opt/lm-studio/chrome_crashpad_handler
	fi

	vmkdir usr/bin
	ln -sf /opt/lm-studio/lm-studio ${DESTDIR}/usr/bin/lmstudio

	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/lm-studio.desktop <<EOF
[Desktop Entry]
Name=LM Studio
Comment=Run LLMs locally (Llama, Mistral, etc.)
# Добавляем --no-sandbox, чтобы обойти ограничения ядра Void
Exec=lmstudio --no-sandbox --enable-features=UseOzonePlatform --ozone-platform=wayland %U
Icon=lmstudio
Type=Application
Categories=Development;ArtificialIntelligence;
Terminal=false
StartupWMClass=LM Studio
EOF

	if [ -f ${FILESDIR}/lmstudio.png ]; then
		vinstall ${FILESDIR}/lmstudio.png 644 usr/share/pixmaps
		vinstall ${FILESDIR}/lmstudio.png 644 usr/share/icons/hicolor/256x256/apps lmstudio.png
	fi
}
